  "keyFeatures": [
    "Endpoint Discovery - Automatic API inventory from network traffic",
    "Sensitive Data Scanning - PII detection with risk scoring",
    "Attack Detection - Real-time identification of malicious requests",
    "Attack Blocking - Automatic blocking of bad actors",
    "API Security Testing - Built-in framework for OWASP Top 10 vulnerabilities",
    "Traffic Mirroring - AWS and GCP traffic mirror setup",
    "Multi-language Support - Agents for Node.js, Python, Java, and Go",
    "CI/CD Integration - Security testing in development and staging"
  ],
  "publicApiSurface": [
    "CLI: metlo init - Initialize Metlo CLI configuration",
    "CLI: metlo test generate - Generate security tests",
    "CLI: metlo test run - Execute security tests",
    "CLI: metlo traffic-mirror aws - Setup AWS traffic mirroring",
    "CLI: metlo traffic-mirror gcp - Setup GCP traffic mirroring",
    "CLI: metlo template - Manage custom test templates",
    "CLI: metlo fuzz - Fuzz testing for APIs",
    "Agent: metlo (Node.js) - Express/Koa/Fastify middleware",
    "Agent: metlo (Python) - Django/Flask middleware",
    "Agent: metlo (Java) - Spring/Spring Reactive filters",
    "Agent: metlo (Go) - Gin/Gorilla middleware",
    "API: /api/v1/endpoints - Manage API endpoints",
    "API: /api/v1/alerts - Configure alerts",
    "API: /api/v1/testing - Manage security tests",
    "API: /api/v1/data-classes - Handle sensitive data classification"
  ]
